<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>The Tech Multiverse Is Wild</title>

  <style>
    body {
      margin: 0;
      font-family: 'Segoe UI', sans-serif;
      background-color: #f5f5f3;
      color: #2f2f2f;
      line-height: 1.7;
    }

    /* subtle grid background */
    body::before {
      content: "";
      position: fixed;
      width: 100%;
      height: 100%;
      background-image: 
        linear-gradient(to right, rgba(0,0,0,0.03) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(0,0,0,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
      z-index: -1;
    }

    .container {
      max-width: 800px;
      margin: auto;
      padding: 40px 20px;
    }

    h1 {
      font-size: 2.5rem;
      color: #3e2f2f;
      margin-bottom: 10px;
    }

    .subtitle {
      color: #7a6f6f;
      font-size: 1rem;
      margin-bottom: 30px;
    }

    h2 {
      margin-top: 40px;
      color: #4a3f35;
    }

    p {
      margin: 15px 0;
    }

    ul {
      margin-left: 20px;
    }

    li {
      margin: 8px 0;
    }

    .highlight {
      background-color: #e8e3dc;
      padding: 2px 6px;
      border-radius: 4px;
    }

    .quote {
      border-left: 4px solid #8b6f47;
      padding-left: 15px;
      margin: 20px 0;
      color: #5c5148;
      font-style: italic;
    }

    .footer {
      margin-top: 60px;
      font-size: 0.9rem;
      color: #888;
